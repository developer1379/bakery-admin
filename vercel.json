{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/(css|js|images)/(.*)",
      "dest": "/$1/$2"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(index|login|logout|orders|products|analytics|ovens|inventory|settings)\\.html",
      "dest": "/$1.php"
    },
    {
      "src": "/(index|login|logout|orders|products|analytics|ovens|inventory|settings)",
      "dest": "/$1.php"
    },
    {
      "src": "/$",
      "dest": "/index.php"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
